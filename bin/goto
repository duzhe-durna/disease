#!/usr/bin/env sh
set -e

pgrep wmenu >/dev/null && exit

target=$( printf "$HOME/%s\n" \
     "Babies/"      \
     "Downloads/"   \
     ".config/"     \
     ".local/bin/"  \
     "Apps/"        \
     | xargs -I PATH find -L PATH -maxdepth 1 | menu -l 10)

if [ -z "$target" ]; then
    exit
elif [ -d "$target" ]; then
    edit_file=
    target="${target%/}"
    dir="$target"
    head="${target##*/}"
    parent="${target%/*}"
    tail="${parent##*/}"
elif [ -f "$target" ]; then
    edit_file="edit %{$target}"
    dir="${target%/*}"
    head="${target##*/}"
    tail="${dir##*/}"
else
    echo "Invalid target: $target"
    exit
fi

cd "$dir"

if [ "$EDITOR" != 'kak' ]; then
    exit
fi

session_name=$(printf %s "${tail}-${head}" | tr ' ' '-' | tr -d '.')
kak -C $session_name -e "daemonize-session; try %{cd src; edit main.rs} catch %{$edit_file}"
