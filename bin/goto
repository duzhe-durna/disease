#!/usr/bin/env nu

def main []: nothing -> nothing {
    if not (pgrep wmenu | is-empty) { return }

    # TODO: allow selecting files
    let target = [
        "Babies/"
        "Downloads/"
        ".config/"
        ".local/bin/"
        "Apps/"
    ]
    | each { [ $env.HOME $in ] | path join }
    | each { ls -al $in }
    | flatten
    | each { |entry| $entry.target? | default $entry.name }
    | str join (char newline)
    | menu -l 10

    if ($target | is-empty) or not ($target | path exists) { 
        return (error make $'Invalid path: ($target)') 
    }

    let dir = if ($target | path type) == dir { $target } else { $target | dirname }
    cd $dir

    if $env.EDITOR != 'kak' {
        $env.EDITOR
        return
    }

    let session_name = $target
        | path parse
        | $"($in.parent | path basename)_($in.stem)"
        | str replace -ar [\s\.]+ _
        | str trim --char _

    let args = [ -C $session_name -e "daemonize-session; try %{cd src}" ]
        | if ($target | path type) != dir { $in | append $target } else { $in }

    kak ...$args
}
