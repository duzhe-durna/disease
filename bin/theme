#!/usr/bin/env sh

set -ex

pgrep menu >/dev/null && exit

# # TODO: "rose-pine" "gruv-light" "kanagawa" "lotus"
themes='rose-pine-moon
rose-pine-dawn'

selected=$(printf %s "$themes" | menu)

if [ -z "$selected" ] || ! printf %s "$themes" | grep -Fq -- "$selected" ; then
    echo aboba
    exit
fi

# sway
sway_path="$HOME/.config/sway"
printf "include '$selected'" > "$sway_path/theme"
swaymsg "$(cat "$sway_path/$selected")"

# kak
kak_cmd="colorscheme $selected"
printf "$kak_cmd" > "$HOME/.config/kak/theme"
for session in $(kak -l); do
    printf "$kak_cmd" | kak -p "$session"
done

# alacritty
printf %s "general.import = ['./$selected.toml']" > "$HOME/.config/alacritty/theme"

# waybar
printf %s "@import \"$selected\";" > "$HOME/.config/waybar/theme"

# wmenu
wmenu_path="$HOME/.config/wmenu"
cat "$wmenu_path/$selected" > "$wmenu_path/theme"
