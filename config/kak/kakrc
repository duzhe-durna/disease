    keys='h j k l H J K L 
        o I O A  
        t T f F g G ] [  
        b w e B W E  
        x X 
        c C d 
        m M n N '

    for k in $keys; do
        printf %s "map global insert <a-$k> '<esc>$k' ; "
    done
}

