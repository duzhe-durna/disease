def find-file \
-docstring 'Fuzzy search for the files from specified directory'\
-override \
-params 1 \
%{ eval %sh{printf %s "
    prompt -menu  -shell-script-candidates %{
        find $@ -type f \
            -not -path '*/node_modules/*' \
            -not -path '*/colors/*' \
            -not -path '*/\.*/*' \
            -not -path '*/target/*'
    }  'File: ' %{
        edit -existing %val{text} 
    }"
} } 

