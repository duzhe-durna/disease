declare-option -docstring 'Saved output of "run-shell" command' \
    str shell_run_output
declare-option -docstring 'Saved exit status of "run-shell" command' \
    int shell_run_status

def sh \
-docstring 'Runs shell command and saves output into "shell_run_output"' \
-override \
-shell-completion \
-params 1.. \
%{
    set global shell_run_output %sh{
        out=$({ eval "$@"; } 2>&1)
        out+="\n\n$?"
        echo "$out"
    }

    set global shell_run_status %sh{
        echo "${kak_opt_shell_run_output##*'\n\n'}"
    }

    set global shell_run_output %sh{
        echo "${kak_opt_shell_run_output%%'\n\n'*}"
    }

    eval %sh{
        if [ $kak_opt_shell_run_status -eq 0 ]; then
            echo "echo -markup %{{Prompt}'$*' Done..}"
        else
            echo "echo -markup %{{Error}'$*' Error..}"
        fi

        if [ -n "$kak_opt_shell_run_output" ]; then
            echo "info %opt{shell_run_output}"
        fi
    }
}

def close-buffers \
-docstring 'The current and the *debug* buffers will be ignored' \
-override \
-buffer-completion \
-params 1 \
%{ eval %sh{
    cmd=
    for b in $kak_buflist; do
        [[ "$b" == "$kak_bufname" ]] && continue
        [[ "$b" == "*debug*" ]] && continue
        [[ "$b" =~ $1 ]] && cmd+="db '$b'; " 
    done
    printf %s "$cmd" 
} }

