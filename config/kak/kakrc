def surround-selection-key \
-override \
-params ..1 \
%{ on-key %{ eval -save-regs 'ocm' %{
eval %sh{
    spc=""
    [ -n "$1" ] && spc=" "
    o="$kak_key"
    c="$kak_key"
    case "$o" in
        "<esc>") exit 0 ;;
        "<quote>") o="'" c="'" ;;
        "<dquote>")  o='"' c='"' ;;
        "<lt>" | "<gt>") o="<" c=">" ;;
        "(" | ")") o="(" c=")" ;;
        "[" | "]") o="[" c="]" ;;
        "{") c="}" ;;
    esac
    o="$o$spc"
    c="$spc$c"
    printf %s "set-register c %┬Č$c┬Č ;
               set-register o %┬Č$o┬Č ;"
}
    surround-selection "%reg{o}" "%reg{c}"
} } }
map global normal <a-'> ':surround-selection-key<ret>'
map global normal <a-"> ':surround-selection-key sooqa<ret>'

