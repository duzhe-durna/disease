# Cursor color change on entering insert mode 
hook global -group insert-color ModeChange push:.*:insert %{
    set-face buffer PrimaryCursor InsertCursor
    set-face buffer PrimaryCursorEol InsertCursor
}
hook global -group insert-color ModeChange .*:insert:normal %{ try %{
    unset-face buffer PrimaryCursor
    unset-face buffer PrimaryCursorEol
} }

def -hidden write-buffer-if-modified %{ eval -draft %sh{ [ $kak_modified = true ] && printf %s "write" }  }

# Auto-save
decl bool auto_save_enabled true
hook global -group auto-save-manager BufSetOption auto_save_enabled=true %{
    hook -group auto-save buffer ModeChange .*:insert:.* write-buffer-if-modified
    hook -group auto-save buffer NormalKey (q|d|<a-d>|c|<a-c>|r|R|p|P|u|U|<lt>|<a-lt>|<gt>|<a-gt>|!|:|\|`|~) write-buffer-if-modified
}

hook global -group auto-save-manager BufSetOption auto_save_enabled=false %{ rmhooks buffer auto-save }

# Per filetype settings
hook global WinSetOption filetype=(yaml|json|markdown) %{
    rmhooks window markdown-trim-indent 
    set buffer tabstop 2
    set buffer indentwidth 2
}
hook global BufOpenFile .*\.wgsl %{
    set buffer filetype rust
}
hook global BufSetOption filetype=git.* %{
    set buffer auto_save_enabled false
}

