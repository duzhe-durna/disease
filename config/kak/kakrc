declare-option -hidden str current_langmap 'en'

def set-langmap \
-override \
-params 1 \
%{ evaluate-commands %sh{
    DEFAULT="\`~1!2@3#4\$5%6^7&8*9(0)_=+\\|qQwWeErRtTyYuUiIoOpP[{]}aAsSdDfFgGhHjJkKlL;:'\"zZxXcCvVbBnNmM,<.>/?"
    RU="čæąü1!2\"3Ōä¢4;5%6:7?8*9(0)_=+\\|ą╣ąÖčåą”čāąŻą║ąÜąĄąĢąĮąØą│ąōčłą©čēą®ąĘąŚčģąźčŖą¬čäążčŗą½ą▓ąÆą░ąÉą┐ą¤čĆąĀąŠą×ą╗ąøą┤ąöąČą¢čŹąŁčÅą»čćą¦čüąĪą╝ą£ąĖąśčéąóčīą¼ą▒ąæčÄą«.,"
    UA="'╩╝1!2\"3Ōä¢4;5%6:7?8*9(0)_=+ęæęÉą╣ąÖčåą”čāąŻą║ąÜąĄąĢąĮąØą│ąōčłą©čēą®ąĘąŚčģąźčŚąćčäążč¢ąåą▓ąÆą░ąÉą┐ą¤čĆąĀąŠą×ą╗ąøą┤ąöąČą¢čöąäčÅą»čćą¦čüąĪą╝ą£ąĖąśčéąóčīą¼ą▒ąæčÄą«.,"
    NEW_CURRENT="$1"
    ALT_MAP=""
    ACTION="map"
    if [[ $NEW_CURRENT == "en" || $NEW_CURRENT == $kak_opt_current_langmap ]]; then
        printf "echo -debug I MA HERE 222;"
        NEW_CURRENT="en"
        ACTION="unmap"
        case $kak_opt_current_langmap in
            "ua") ALT_MAP="$UA" ;;
            "ru") ALT_MAP="$RU" ;;
            *) exit ;;
        esac
    elif [[ $NEW_CURRENT == "ua" ]]; then
        printf "echo -debug I MA HERE $kak_opt_current_langmap;"
        ALT_MAP="$UA"
    elif [[ $NEW_CURRENT == "ru" ]]; then
        ALT_MAP="$RU"
    else
        printf "fail Unsupported langmap: $NEW_CURRENT"
        exit
    fi
    CMD=()
    for ((i=0; i < ${#DEFAULT}; i++)); do
        CMD+=("${ACTION} global insert %┬¦${DEFAULT:i:1}┬¦ %┬¦${ALT_MAP:i:1}┬¦; ")
    done
    printf %s "${CMD[*]}; set global current_langmap $NEW_CURRENT"
} }

