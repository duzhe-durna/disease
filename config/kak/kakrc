eval %sh{
    autoload_directory() {
        find -L "$1" -type f -name '*\.kak' \
            | sed 's/.*/try %{ source "&" } catch %{ echo -debug Autoload: could not load "&" }/'
    }

    if [ -d "${kak_runtime}/autoload" ]; then
        autoload_directory ${kak_runtime}/autoload
    fi
}

def -override -params 1 -docstring "colorscheme <name>: enable named colorscheme" colorscheme %{
    source "%val{runtime}/colors/%arg{1}.kak"
}
compl -menu colorscheme shell-script-candidates %{
    find -L "${kak_runtime}/colors" -type f -name '*\.kak' | while read -r filename; do
        basename="${filename##*/}"
        printf %s\\n "${basename%.*}"
    done | sort -u
}

def -override terminal -docstring 'Open terminal with optional command to run' -params ..1 %{ eval %sh{
    if [ $# -gt 0 ]; then
        alacritty msg create-window --working-directory $PWD -e sh -c "$@"
    else 
        alacritty msg create-window --working-directory $PWD
    fi
} }

def terminal-vertical -params ..1 %{
    nop %sh{swaymsg split vertical}
    terminal %arg[@]
}

def terminal-horizontal -params ..1 %{
    nop %sh{swaymsg split horizontal}
    terminal %arg[@]
}

def terminal-tab -params ..1 %{
    nop %sh{swaymsg 'split horizontal; layout tabbed'}
    terminal %arg[@]
}

decl -hidden str buf_split_cmd
def -hidden update-buf-slit-cmd %{ set global buf_split_cmd %exp{
    kak -c '%val{session}' -e "buffer '%val{bufname}' ; select %val{selection_desc} ; exec vv"
} }

def buffer-split-vertical %{
    update-buf-slit-cmd
    terminal-vertical %opt{buf_split_cmd}
}

def buffer-split-horizontal %{
    update-buf-slit-cmd
    terminal-horizontal %opt{buf_split_cmd}
}

def buffer-split-tab %{
    update-buf-slit-cmd
    terminal-tab %opt{buf_split_cmd}
}

def kill-session -params 1 %{ kill %arg{1} }
compl -menu kill-session shell-script-candidates %{kak -l}

def copy-sys-clipboard %{ eval %sh{ wl-copy -- "$kak_selection" 2>/dev/null } }
def paste-sys-clipboard -params 1 %{ eval -save-regs dquote %{
    reg dquote %sh{wl-paste 2>/dev/null}
    exec %arg{1}
} } 

def selected-camel-into-screaming-snake %{ exec -draft -itersel 's(?<lt>=[a-z])[A-Z]<ret>i_<esc><a-i>w~' }
def selected-camel-into-snake %{ exec -draft -itersel 's(?<lt>=[a-z])[A-Z]<ret>i_<esc><a-i>w`'}

def cdhere -docstring 'CD to the current buffile location' %{ cd %sh{ echo $(dirname "$kak_buffile") } }

def eval-selected %{ eval %val{selection} }

def eval-selected-all-sessions %{ eval %sh{
     cmd="$kak_selection"
     for s in $(kak -l); do
        echo "$cmd" | kak -p "$s"
     done
} }

def swap-selections %{ try %{ exec '<a-z>a<a-)>' } }

def surround-selection -params 1..2 %{ eval -save-regs 'ocz' %{
    set-register o %arg{1}
    set-register c %arg{2}
    exec -draft -itersel 'Z"oPz"cpz'
} }

def surround-selection-key -params ..1 %{ on-key %{ eval -save-regs 'ocm' %{
    eval %sh{
        spc=""
        [ -n "$1" ] && spc=" "
        o="$kak_key"
        c="$kak_key"
        case "$o" in
            "<esc>") exit 0 ;;
            "<quote>") o="'" c="'" ;;
            "<dquote>")  o='"' c='"' ;;
            "<lt>" | "<gt>") o="<" c=">" ;;
            "(" | ")") o="(" c=")" ;;
            "[" | "]") o="[" c="]" ;;
            "{") c="}" ;;
        esac
        o="$o$spc"
        c="$spc$c"
        printf %s "set-register c %¶$c¶ ;
                   set-register o %¶$o¶ ;"
    }

    surround-selection "%reg{o}" "%reg{c}"
} } }

def remove-matching-forward %{exec -save-regs '^"' 'mm;Zm;dzd'}

def remove-matching-backward %{exec -save-regs '^"' '<a-m><a-m>;Zm;dzd'}

decl -hidden str find_edit_path
def find-edit-file -docstring %{
    Fuzzy search for the files from specified directory
} -params 1 %{
    set current find_edit_path %arg[1]
    prompt -menu  -shell-script-candidates %{
        find $kak_opt_find_edit_path -type f \
            -not -path '*/node_modules/*' \
            -not -path '*/target/*'
    }  'edit ' %{ edit -existing %val{text}  }
} 

def find-edit-buffer -docstring 'Open an exising buffer' %{
    prompt -menu -buffer-completion 'Buffer: ' %{buffer %val{text}}
}

def ls -docstring 'List files in the current directory' -file-completion %{
    eval %sh{ printf %s "info -title '$PWD' '$(ls -Alh)'" }
}

def lang -docstring 'Set a filetype for current buffer' -params 1 %{ set-option buffer filetype %arg{1} }

decl -hidden str current_langmap 'en'
def set-langmap -params 1 %{ eval %sh{
    default="\`~1!2@3#4\$5%6^7&8*9(0)_=+\\|qQwWeErRtTyYuUiIoOpP[{]}aAsSdDfFgGhHjJkKlL;:'\"zZxXcCvVbBnNmM,<.>/?"
    ru="ёЁ1!2\"3№4;5%6:7?8*9(0)_=+\\|йЙцЦуУкКеЕнНгГшШщЩзЗхХъЪфФыЫвВаАпПрРоОлЛдДжЖэЭяЯчЧсСмМиИтТьЬбБюЮ.,"
    ua="'ʼ1!2\"3№4;5%6:7?8*9(0)_=+ґҐйЙцЦуУкКеЕнНгГшШщЩзЗхХїЇфФіІвВаАпПрРоОлЛдДжЖєЄяЯчЧсСмМиИтТьЬбБюЮ.,"
    new_current="$1"
    alt_map=""
    action="map"
    if [ "$new_current" = "en" ] || [ "$new_current" = "$kak_opt_current_langmap" ]; then
        new_current="en"
        action="unmap"
        case $kak_opt_current_langmap in
            ua) alt_map="$ua" ;;
            ru) alt_map="$ru" ;;
            *) exit 1 ;;
        esac
    elif [ "$new_current" = "ua" ]; then
        alt_map="$ua"
    elif [ "$new_current" = "ru" ]; then
        alt_map="$ru"
    else
        echo "fail Unsupported langmap: $new_current"
        exit 1
    fi

    cmd=""
    for ((i=0; i < ${#default}; i++)); do
        cmd+="${action} global insert %§${default:i:1}§ %§${alt_map:i:1}§; "
    done
    printf %s "${cmd}; set global current_langmap $new_current"
} }

