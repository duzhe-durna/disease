# alt + <anyaction> to escape insert mode
evaluate-commands %sh{
    keys='h j k l H J K L '
    keys+='o I O A ' 
    keys+='t T f F g G ] [ ' 
    keys+='b w e B W E ' 
    keys+='x X '
    keys+='c C d '
    keys+='m M n N '
    cmd=""
    for k in $keys; do
        cmd+="map global insert <a-$k> '<esc>$k' ; "
    done
    printf %s "eval %{ $cmd }"
}

