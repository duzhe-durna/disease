#[derive(Parser)]
enum Cmd {
    Init,
    Switch { current: LangMap, next: LangMap },
}

fn switch(current: LangMap, next: LangMap) {
    let mut out = BufWriter::new(std::io::stdout());

    let (action, next_str) = match (&current, &next) {
        (current, next) if current == next => ("unmap", LangMap::En.as_str()),
        (_, LangMap::En) => ("unmap", next.as_str()),
        _ => ("map", next.as_str()),
    };

    for char_ in LANG_MAP_CHARS {
        let _ = writeln!(
            out,
            r#"{action} global insert %§{current_char}§ %§{new_char}§"#,
            current_char = char_[LangMap::En as usize],
            new_char = char_[next as usize],
        );
    }

    let _ = writeln!(out, "set-option global current_langmap {next_str}");
}

fn kak_init() {
    let exe_path = std::env::current_exe().expect("current exe path");
    println!(
        r#"provide-module langmap %(
            decl -hidden str current_langmap 'en'
            def switch-langmap -params 1 -docstring %(
                switch-langmap <next langmap>
                Available langmaps: {available:?}
            ) %(eval %sh("{this_exe}" switch "$kak_opt_current_langmap" "$1"))
        )"#,
        available = langmap_list(),
        this_exe = exe_path.display(),
    )
}

fn langmap_list() -> [&'static str; LangMap::COUNT] {
    std::array::from_fn(|i| LangMap::VARIANTS[i].as_str())
}

impl LangMap {
    fn as_str(&self) -> &'static str {
        match self {
            LangMap::En => "en",
            LangMap::Ru => "ru",
            LangMap::Ua => "ua",
        }
    }
}

impl std::str::FromStr for LangMap {
    type Err = String;
    fn from_str(it: &str) -> Result<Self, Self::Err> {
        Self::VARIANTS
            .iter()
            .find(|langmap| langmap.as_str() == it)
            .copied()
            .ok_or_else(|| format!("'{it}' if undefined langmap"))
    }
}

#[macro_export]
macro_rules! enum_LangMap {
    ($($variant:ident),*) => {
        #[derive(Copy, Clone, Eq, PartialEq, Debug)]
        enum LangMap {
            $($variant,)*
        }

        impl LangMap {
            const VARIANTS: &[Self] = &[ $(Self::$variant,)* ];
            const COUNT: usize = Self::VARIANTS.len();
        }
    }
}

fn main() {
    match Cmd::try_parse() {
        Ok(Cmd::Init) => kak_init(),
        Ok(Cmd::Switch { current, next }) => switch(current, next),
        Err(err) => {
            println!("fail langmap command failed");
            eprintln!("{err}");
        }
    }
}
